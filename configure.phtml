<?php
// ── Domain objects (no FreshRSS autoloader here) ────────────────────────────
foreach ([
    __DIR__ . '/Services/ButtonField.php',
    __DIR__ . '/Services/AiButton.php',
    __DIR__ . '/Services/AiButtonCollection.php',
] as $_f) { require_once $_f; }

// ── Load current button collection ──────────────────────────────────────────
$buttons_json = (string)(FreshRSS_Context::$user_conf->oai_buttons ?? '');
$buttons      = AiButtonCollection::fromJson($buttons_json);

if ($buttons->isEmpty()) {
    // Legacy fallback: migrate old flat config to AiButton objects
    $legacy_url   = (string)(FreshRSS_Context::$user_conf->oai_url      ?? '');
    $legacy_key   = (string)(FreshRSS_Context::$user_conf->oai_key      ?? '');
    $legacy_model = (string)(FreshRSS_Context::$user_conf->oai_model    ?? '');
    $legacy_p1    = (string)(FreshRSS_Context::$user_conf->oai_prompt   ?? '');
    $legacy_p2    = (string)(FreshRSS_Context::$user_conf->oai_prompt_2 ?? '');
    $legacy = [];
    if (trim($legacy_p1) !== '') {
        $legacy[] = new AiButton('Summarize', $legacy_url, $legacy_key, $legacy_model, $legacy_p1);
    }
    if (trim($legacy_p2) !== '') {
        $legacy[] = new AiButton('+', $legacy_url, $legacy_key, $legacy_model, $legacy_p2);
    }
    $buttons = new AiButtonCollection($legacy);
}

$oai_tts_url   = (string)(FreshRSS_Context::$user_conf->oai_tts_url   ?? '');
$oai_tts_key   = (string)(FreshRSS_Context::$user_conf->oai_tts_key   ?? '');
$oai_tts_model = (string)(FreshRSS_Context::$user_conf->oai_tts_model ?? 'tts-1');
$oai_voice     = (string)(FreshRSS_Context::$user_conf->oai_voice     ?? 'alloy');
$oai_speed     = (string)(FreshRSS_Context::$user_conf->oai_speed     ?? '1.1');
?>

<form action="<?php echo _url('extension', 'configure', 'e', urlencode($this->getName())); ?>" method="post">
  <input type="hidden" name="_csrf" value="<?php echo FreshRSS_Auth::csrfToken(); ?>" />

  <fieldset>
    <legend><?php echo RssAiButtonsExtension::t('summary_buttons'); ?></legend>
    <div id="oai-buttons-container">
      <?php foreach ($buttons as $idx => $btn): /** @var AiButton $btn */ ?>
      <div class="oai-btn-slot">
        <h4><?php echo RssAiButtonsExtension::t('button'); ?> <?php echo $idx + 1; ?>
          <button type="button" class="oai-remove-slot btn btn-small"><?php echo RssAiButtonsExtension::t('remove'); ?></button>
        </h4>
        <label><?php echo RssAiButtonsExtension::t('button_label'); ?>
          <input type="text" name="oai_btn[<?php echo $idx; ?>][<?php echo ButtonField::LABEL; ?>]" value="<?php echo htmlspecialchars($btn->label, ENT_QUOTES); ?>">
        </label>
        <label><?php echo RssAiButtonsExtension::t('base_url'); ?>
          <input type="text" name="oai_btn[<?php echo $idx; ?>][<?php echo ButtonField::URL; ?>]" value="<?php echo htmlspecialchars($btn->url, ENT_QUOTES); ?>">
        </label>
        <label><?php echo RssAiButtonsExtension::t('api_key'); ?>
          <input type="text" name="oai_btn[<?php echo $idx; ?>][<?php echo ButtonField::KEY; ?>]" value="<?php echo htmlspecialchars($btn->key, ENT_QUOTES); ?>">
        </label>
        <label><?php echo RssAiButtonsExtension::t('model_name'); ?>
          <input type="text" name="oai_btn[<?php echo $idx; ?>][<?php echo ButtonField::MODEL; ?>]" value="<?php echo htmlspecialchars($btn->model, ENT_QUOTES); ?>">
        </label>
        <label><?php echo RssAiButtonsExtension::t('prompt'); ?>
          <textarea name="oai_btn[<?php echo $idx; ?>][<?php echo ButtonField::PROMPT; ?>]"><?php echo htmlspecialchars($btn->prompt, ENT_QUOTES); ?></textarea>
        </label>
        <label><?php echo RssAiButtonsExtension::t('effort'); ?>
          <select name="oai_btn[<?php echo $idx; ?>][<?php echo ButtonField::EFFORT; ?>]">
            <?php foreach ([
                AiButton::VALID_EFFORTS[0] => RssAiButtonsExtension::t('effort_low'),
                AiButton::VALID_EFFORTS[1] => RssAiButtonsExtension::t('effort_medium'),
                AiButton::VALID_EFFORTS[2] => RssAiButtonsExtension::t('effort_high'),
            ] as $eVal => $eLabel): ?>
            <option value="<?php echo $eVal; ?>"<?php echo $btn->effort === $eVal ? ' selected' : ''; ?>><?php echo htmlspecialchars($eLabel, ENT_QUOTES); ?></option>
            <?php endforeach; ?>
          </select>
        </label>
        <label><?php echo RssAiButtonsExtension::t('button_voice'); ?>
          <input type="text" name="oai_btn[<?php echo $idx; ?>][<?php echo ButtonField::VOICE; ?>]" value="<?php echo htmlspecialchars($btn->voice, ENT_QUOTES); ?>" placeholder="<?php echo RssAiButtonsExtension::t('button_voice_placeholder'); ?>">
        </label>
      </div>
      <?php endforeach; ?>
    </div>
    <button type="button" id="oai-add-btn" class="btn btn-small">+ <?php echo RssAiButtonsExtension::t('add_button'); ?></button>
  </fieldset>

  <fieldset>
    <legend><?php echo RssAiButtonsExtension::t('audio_settings'); ?></legend>
    <p><?php echo RssAiButtonsExtension::t('audio_url_hint'); ?></p>
    <label for="oai_tts_url"><?php echo RssAiButtonsExtension::t('tts_base_url'); ?></label>
    <input type="text" name="oai_tts_url" id="oai_tts_url"
           value="<?php echo htmlspecialchars($oai_tts_url, ENT_QUOTES); ?>"
           placeholder="<?php echo RssAiButtonsExtension::t('tts_url_placeholder'); ?>">
    <label for="oai_tts_key"><?php echo RssAiButtonsExtension::t('tts_api_key'); ?></label>
    <input type="text" name="oai_tts_key" id="oai_tts_key"
           value="<?php echo htmlspecialchars($oai_tts_key, ENT_QUOTES); ?>"
           placeholder="<?php echo RssAiButtonsExtension::t('tts_key_placeholder'); ?>">
    <label for="oai_tts_model"><?php echo RssAiButtonsExtension::t('tts_model'); ?></label>
    <input type="text" name="oai_tts_model" id="oai_tts_model" value="<?php echo htmlspecialchars($oai_tts_model, ENT_QUOTES); ?>">
    <label for="oai_voice"><?php echo RssAiButtonsExtension::t('voice'); ?></label>
    <input type="text" name="oai_voice" id="oai_voice" value="<?php echo htmlspecialchars($oai_voice, ENT_QUOTES); ?>">
    <label for="oai_speed"><?php echo RssAiButtonsExtension::t('speech_speed'); ?></label>
    <input type="number" name="oai_speed" id="oai_speed" min="0.5" max="4" step="0.1" value="<?php echo htmlspecialchars($oai_speed, ENT_QUOTES); ?>">
  </fieldset>

  <hr />
  <button type="submit"><?php echo RssAiButtonsExtension::t('save'); ?></button>
</form>

<script>
(function () {
  var container = document.getElementById('oai-buttons-container');
  var addBtn    = document.getElementById('oai-add-btn');
  var btnLabel  = <?php echo json_encode(RssAiButtonsExtension::t('button')); ?>;
  var removeLabel = <?php echo json_encode(RssAiButtonsExtension::t('remove')); ?>;
  var F = <?php echo json_encode([
    'label'  => ButtonField::LABEL,
    'url'    => ButtonField::URL,
    'key'    => ButtonField::KEY,
    'model'  => ButtonField::MODEL,
    'prompt' => ButtonField::PROMPT,
    'effort' => ButtonField::EFFORT,
    'voice'  => ButtonField::VOICE,
  ]); ?>;
  var labels = {
    button_label:             <?php echo json_encode(RssAiButtonsExtension::t('button_label')); ?>,
    base_url:                 <?php echo json_encode(RssAiButtonsExtension::t('base_url')); ?>,
    api_key:                  <?php echo json_encode(RssAiButtonsExtension::t('api_key')); ?>,
    model_name:               <?php echo json_encode(RssAiButtonsExtension::t('model_name')); ?>,
    prompt:                   <?php echo json_encode(RssAiButtonsExtension::t('prompt')); ?>,
    effort:                   <?php echo json_encode(RssAiButtonsExtension::t('effort')); ?>,
    effort_low:               <?php echo json_encode(RssAiButtonsExtension::t('effort_low')); ?>,
    effort_medium:            <?php echo json_encode(RssAiButtonsExtension::t('effort_medium')); ?>,
    effort_high:              <?php echo json_encode(RssAiButtonsExtension::t('effort_high')); ?>,
    button_voice:             <?php echo json_encode(RssAiButtonsExtension::t('button_voice')); ?>,
    button_voice_placeholder: <?php echo json_encode(RssAiButtonsExtension::t('button_voice_placeholder')); ?>
  };

  function reindex() {
    var slots = container.querySelectorAll('.oai-btn-slot');
    slots.forEach(function (slot, i) {
      slot.querySelectorAll('input, textarea, select').forEach(function (el) {
        el.name = el.name.replace(/oai_btn\[\d+\]/, 'oai_btn[' + i + ']');
      });
      var h4 = slot.querySelector('h4');
      if (h4) h4.firstChild.textContent = btnLabel + ' ' + (i + 1) + ' ';
    });
  }

  container.addEventListener('click', function (e) {
    if (e.target.classList.contains('oai-remove-slot')) {
      var slot = e.target.closest('.oai-btn-slot');
      if (slot) { slot.remove(); reindex(); }
    }
  });

  addBtn.addEventListener('click', function () {
    var slots  = container.querySelectorAll('.oai-btn-slot');
    var idx    = slots.length;
    var first  = slots[0];
    var defUrl   = first ? (first.querySelector('input[name*="[' + F.url   + ']"]') || {}).value || '' : '';
    var defKey   = first ? (first.querySelector('input[name*="[' + F.key   + ']"]') || {}).value || '' : '';
    var defModel = first ? (first.querySelector('input[name*="[' + F.model + ']"]') || {}).value || '' : '';

    var slot = document.createElement('div');
    slot.className = 'oai-btn-slot';
    slot.innerHTML =
      '<h4>' + btnLabel + ' ' + (idx + 1) + ' ' +
        '<button type="button" class="oai-remove-slot btn btn-small">' + removeLabel + '</button></h4>' +
      '<label>' + labels.button_label + '<input type="text" name="oai_btn[' + idx + '][' + F.label  + ']" value=""></label>' +
      '<label>' + labels.base_url     + '<input type="text" name="oai_btn[' + idx + '][' + F.url    + ']" value="' + defUrl   + '"></label>' +
      '<label>' + labels.api_key      + '<input type="text" name="oai_btn[' + idx + '][' + F.key    + ']" value="' + defKey   + '"></label>' +
      '<label>' + labels.model_name   + '<input type="text" name="oai_btn[' + idx + '][' + F.model  + ']" value="' + defModel + '"></label>' +
      '<label>' + labels.prompt       + '<textarea name="oai_btn[' + idx + '][' + F.prompt + ']"></textarea></label>' +
      '<label>' + labels.effort       + '<select name="oai_btn[' + idx + '][' + F.effort + ']">' +
        '<option value="low">'    + labels.effort_low    + '</option>' +
        '<option value="medium">' + labels.effort_medium + '</option>' +
        '<option value="high">'   + labels.effort_high   + '</option>' +
      '</select></label>' +
      '<label>' + labels.button_voice + '<input type="text" name="oai_btn[' + idx + '][' + F.voice + ']" value="" placeholder="' + labels.button_voice_placeholder + '"></label>';
    container.appendChild(slot);
  });
})();
</script>

